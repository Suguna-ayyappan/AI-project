void onBeatDetected() {
  Serial.println(">> Beat!");
  // Flash heart on OLED briefly
  oled.fillRect(100, 0, 28, 16, BLACK);
  oled.setTextSize(1);
  oled.setTextColor(WHITE);
  oled.setCursor(100, 4);
  oled.print("<3");
  oled.display();
}

// ─────────────────────────────────────────────────────────────
// OLED draw helpers
// ─────────────────────────────────────────────────────────────

// Draw a thick horizontal divider line
void oledDivider(int y) {
  oled.drawFastHLine(0, y, SCREEN_WIDTH, WHITE);
}

// Screen 0 — Heart Rate
void oledShowBPM() {
  oled.clearDisplay();
  // Title bar
  oled.fillRect(0, 0, 128, 14, WHITE);
  oled.setTextColor(BLACK);
  oled.setTextSize(1);
  oled.setCursor(32, 3);
  oled.print("HEART RATE");
  // Value
  oled.setTextColor(WHITE);
  oled.setTextSize(3);
  String val = BPM > 0 ? String((int)BPM) : "--";
  int xOff = (BPM > 99) ? 14 : (BPM > 9 ? 26 : 44);
  oled.setCursor(xOff, 20);
  oled.print(val);
  // Unit
  oled.setTextSize(1);
  oled.setCursor(100, 52);
  oled.print("BPM");
  // Bottom divider
  oledDivider(50);
  // Status dot
  oled.fillCircle(6, 57, 4, WHITE);
  oled.setCursor(14, 54);
  oled.print(BPM > 110 ? "HIGH ALERT" : "Normal");
  oled.display();
}

// Screen 1 — SpO2
void oledShowSpO2() {
  oled.clearDisplay();
  oled.fillRect(0, 0, 128, 14, WHITE);
  oled.setTextColor(BLACK);
  oled.setTextSize(1);
  oled.setCursor(40, 3);
  oled.print("SpO2");
  oled.setTextColor(WHITE);
  oled.setTextSize(3);
  String val = SpO2 > 0 ? String((int)SpO2) : "--";
  int xOff = (SpO2 > 99) ? 14 : 26;
  oled.setCursor(xOff, 20);
  oled.print(val);
  oled.setTextSize(1);
  oled.setCursor(104, 20);
  oled.print("%");
  oledDivider(50);
  oled.fillCircle(6, 57, 4, WHITE);
  oled.setCursor(14, 54);
  oled.print((SpO2 < 95 && SpO2 > 0) ? "LOW ALERT" : "Normal");
  oled.display();
}

// Screen 2 — Temperature
void oledShowTemp() {
  oled.clearDisplay();
  oled.fillRect(0, 0, 128, 14, WHITE);
  oled.setTextColor(BLACK);
  oled.setTextSize(1);
  oled.setCursor(24, 3);
  oled.print("TEMPERATURE");
  oled.setTextColor(WHITE);
  oled.setTextSize(3);
  String val = TEMP > 0 ? String(TEMP, 1) : "--";
  oled.setCursor(10, 20);
  oled.print(val);
  oled.setTextSize(1);
  oled.setCursor(110, 20);
  oled.print("C");
  oledDivider(50);
  oled.fillCircle(6, 57, 4, WHITE);
  oled.setCursor(14, 54);
  oled.print((TEMP > 38 && TEMP > 0) ? "HIGH ALERT" : "Normal");
  oled.display();
}

// Alert screen — overrides normal rotation
void oledShowAlert(String line1, String line2) {
  oled.clearDisplay();
  // Flashing border
  oled.drawRect(0, 0, 128, 64, WHITE);
  oled.drawRect(2, 2, 124, 60, WHITE);
  // Alert icon
  oled.setTextSize(2);
  oled.setTextColor(WHITE);
  oled.setCursor(56, 6);
  oled.print("!");
  oledDivider(26);
  oled.setTextSize(1);
  oled.setCursor(2, 30);
  oled.print(line1);
  oled.setCursor(2, 44);
  oled.print(line2);
  oled.display();
}

// Called every OLED_PERIOD_MS
void updateOLED() {
  bool bpmWarn  = BPM  > 110;
  bool spo2Warn = SpO2 < 95 && SpO2 > 0;
  bool tempWarn = TEMP > 38  && TEMP > 0;

  if (bpmWarn || spo2Warn || tempWarn) {
    String l1 = "*** ALERT ***";
    String l2 = "";
    if      (bpmWarn)  l2 = "High BPM: " + String((int)BPM);
    else if (spo2Warn) l2 = "Low SpO2: " + String((int)SpO2) + "%";
    else if (tempWarn) l2 = "Hi Temp:  " + String(TEMP, 1) + "C";
    oledShowAlert(l1, l2);
    return;
  }

  switch (oledScreen % 3) {
    case 0: oledShowBPM();  break;
    case 1: oledShowSpO2(); break;
    case 2: oledShowTemp(); break;
  }
  oledScreen++;
}

// Startup splash screen
void oledSplash(String l1, String l2) {
  oled.clearDisplay();
  oled.setTextColor(WHITE);
  oled.setTextSize(1);
  oled.setCursor(0, 10);
  oled.println(l1);
  oled.setCursor(0, 30);
  oled.println(l2);
  oled.display();
}

// ─────────────────────────────────────────────────────────────
// Sensor history
// ─────────────────────────────────────────────────────────────
void pushHistory(float b, float s, float t) {
  bpmHistory[historyIndex]  = b;
  spo2History[historyIndex] = s;
  tempHistory[historyIndex] = t;
  timeHistory[historyIndex] = millis() / 1000;
  historyIndex = (historyIndex + 1) % MAX_HISTORY;
  if (historyCount < MAX_HISTORY) historyCount++;
}

// ─────────────────────────────────────────────────────────────
// HTTP endpoints
// ─────────────────────────────────────────────────────────────
void handleHistory() {
  String json = "[";
  int start = (historyCount < MAX_HISTORY) ? 0 : historyIndex;
  for (int i = 0; i < historyCount; i++) {
    int idx = (start + i) % MAX_HISTORY;
    if (i > 0) json += ",";
    json += "{\"bpm\":"  + String(bpmHistory[idx],  1) + ",";
    json += "\"spo2\":" + String(spo2History[idx], 1) + ",";
    json += "\"temp\":" + String(tempHistory[idx], 2) + ",";
    json += "\"ts\":"   + String(timeHistory[idx])    + "}";
  }
  json += "]";
  server.send(200, "application/json", json);
}

void handleData() {
  String json = "{\"bpm\":"  + String(BPM,  1) + ",";
  json        += "\"spo2\":" + String(SpO2, 1) + ",";
  json        += "\"temp\":" + String(TEMP, 2) + ",";
  json        += "\"ts\":"   + String(millis() / 1000) + "}";
  server.send(200, "application/json", json);
}

void handleManifest() {
  String m = "{\"name\":\"Pulse Oximeter\",";
  m += "\"short_name\":\"PulseOx\",";
  m += "\"start_url\":\"/\",\"display\":\"standalone\",";
  m += "\"background_color\":\"#0f172a\",\"theme_color\":\"#ef4444\",";
  m += "\"orientation\":\"portrait\",";
  m += "\"icons\":[{\"src\":\"/icon\",\"sizes\":\"192x192\",\"type\":\"image/svg+xml\"}]}";
  server.send(200, "application/manifest+json", m);
}

void handleIcon() {
  String svg = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'>";
  svg += "<rect width='192' height='192' rx='40' fill='#0f172a'/>";
  svg += "<text x='96' y='130' font-size='110' text-anchor='middle' fill='#ef4444'>&#10084;</text>";
  svg += "</svg>";
  server.send(200, "image/svg+xml", svg);
}

void handle404() { server.send(404, "text/plain", "Not found"); }

