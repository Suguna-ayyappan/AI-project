  oledSplash("Init MAX30100", "Place finger...");
  Serial.print("Initializing MAX30100...");
  if (!pox.begin()) {
    Serial.println("FAILED!");
    oledSplash("MAX30100 FAILED", "Check wiring!");
    while (true);
  }
