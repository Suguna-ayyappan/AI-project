// ═════════════════════════════════════════════════════════════
// Setup
// ═════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(200);

  memset(bpmHistory,  0, sizeof(bpmHistory));
  memset(spo2History, 0, sizeof(spo2History));
  memset(tempHistory, 0, sizeof(tempHistory));
  memset(timeHistory, 0, sizeof(timeHistory));

  Wire.begin(4, 5); // SDA=D2(GPIO4) SCL=D1(GPIO5)

