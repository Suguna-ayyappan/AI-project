  if (!oled.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("OLED init FAILED — check wiring!");
  } else {
    oled.clearDisplay();
    oled.setTextColor(WHITE);
    oled.setTextSize(1);
    oled.setCursor(0, 10);
    oled.println("Pulse Oximeter");
    oled.setCursor(0, 30);
    oled.println("Starting...");
    oled.display();
